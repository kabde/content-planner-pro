msgid "License activated."
msgstr "Licence activée."

#: inc/license.php
msgid "Activation failed."
msgstr "Activation échouée."

#: inc/license.php
msgid "Permission denied."
msgstr "Permission refusée."

#: inc/license.php
msgid "License deactivated."
msgstr "Licence désactivée."

#: inc/license.php
#, php-format
msgid "Please <a href=\"%s\">activate your license</a> to use the plugin."
msgstr "Veuillez <a href=\"%s\">activer votre licence</a> pour utiliser le plugin."

#: inc/license.php
#, php-format
msgid "Your license has expired. <a href=\"%s\">Renew</a>"
msgstr "Votre licence a expiré. <a href=\"%s\">Renouveler</a>"

#: inc/license.php
#, php-format
msgid "Your license expires in %1$d day. <a href=\"%2$s\">View</a>"
msgid_plural "Your license expires in %1$d days. <a href=\"%2$s\">View</a>"
msgstr[0] "Votre licence expire dans %1$d jour. <a href=\"%2$s\">Voir</a>"
